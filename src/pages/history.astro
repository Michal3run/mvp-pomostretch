---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import { HistoryList } from "@/components/history/HistoryList";
import { createClient } from "@/lib/supabase";
import { BREAK_SESSION_LIST_LIMIT } from "@/lib/sessions/types";
import type { BreakSession } from "@/lib/sessions/types";

const { user } = Astro.locals;

// Middleware gates `/history` for unauthenticated callers, but TS doesn't
// know that — narrow defensively here so the rest of this file is type-safe.
if (!user) {
  return Astro.redirect("/auth/signin");
}

const supabase = createClient(Astro.request.headers, Astro.cookies);

let initialItems: BreakSession[] = [];
let loadError: string | null = null;

if (!supabase) {
  loadError = "Backend nie jest skonfigurowany — brak danych do wyświetlenia.";
} else {
  const { data, error } = await supabase
    .from("break_session")
    .select("*")
    .eq("user_id", user.id)
    .order("created_at", { ascending: false })
    .limit(BREAK_SESSION_LIST_LIMIT);

  if (error) {
    loadError = error.message;
  } else {
    initialItems = (data ?? []) as BreakSession[];
  }
}
---

<Layout title="Historia przerw">
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto max-w-3xl">
      <Topbar />

      <header class="mb-6 text-white">
        <h1
          class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent"
        >
          Historia przerw
        </h1>
        <p class="mt-1 text-sm text-blue-100/70">
          Twoje ostatnie przerwy z PomoStretch — z możliwością dopisania notatki lub usunięcia wpisu.
        </p>
      </header>

      {
        loadError ? (
          <div role="alert" class="rounded-lg border border-red-500/40 bg-red-500/10 p-3 text-sm text-red-100">
            {loadError}
          </div>
        ) : (
          <HistoryList client:load initialItems={initialItems} />
        )
      }
    </div>
  </div>
</Layout>
